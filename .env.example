# GitHub Configuration (used for scanning repositories)
GITHUB_USERNAME=
GITHUB_TOKEN=

# Telegram Configuration (used for notifications and chat commands)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Gemini AI Configuration (used for natural language query summarization)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Database Configuration (leave empty to use default local SQLite file: rakshak.db)
# Production can be a PostgreSQL connection string like:
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/rakshak?sslmode=require
DATABASE_URL=sqlite:///./rakshak.db

# Demo/Fallback Mode (1 = enable SQLite seed fallback for Coral queries, 0 = live Coral queries only)
RAKSHAK_DEMO_FALLBACK=0

# Coral WSL/Linux Integration configuration (if Coral is run in wsl)
# 1 = run Coral via wsl CLI, 0 = run natively in current OS
USE_WSL_FOR_CORAL=1
